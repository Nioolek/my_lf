# LangGraph Postgres Runtime Environment
# Copy this file and adjust values as needed

# ── Runtime Edition ──────────────────────────────────────────────────────
LANGGRAPH_RUNTIME_EDITION=postgres_py

# ── PostgreSQL Connection ────────────────────────────────────────────────
DATABASE_URI=postgresql://langgraph:langgraph@localhost:5433/langgraph

# ── Redis Connection ─────────────────────────────────────────────────────
REDIS_URI=redis://localhost:6380

# ── Worker Configuration ─────────────────────────────────────────────────
N_JOBS_PER_WORKER=2

# ── Security ─────────────────────────────────────────────────────────────
# AES key for encryption - MUST be exactly 16, 24, or 32 bytes
LANGGRAPH_AES_KEY=1234567890123456

# ── API Variant ──────────────────────────────────────────────────────────
LANGSMITH_LANGGRAPH_API_VARIANT=local_dev

# ── Network ──────────────────────────────────────────────────────────────
ALLOW_PRIVATE_NETWORK=true
LANGGRAPH_DISABLE_FILE_PERSISTENCE=false

# ── Graph Registration (JSON format) ─────────────────────────────────────
# Maps graph_id to file:variable path
LANGSERVE_GRAPHS={"counter": "./my_graph.py:graph"}